# ============================================================
# Backend Production Environment Variables
# Copy this file to /var/www/sahayai/.env on the VPS
# Fill in all values before starting the server
# ============================================================

# Server
PORT=5000
NODE_ENV=production

# Frontend origin (CORS allow-list)
CLIENT_URL=https://sahayai.synthomind.cloud

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster.4kercf5.mongodb.net/SSH-2026?retryWrites=true&w=majority&appName=Cluster

# JWT — use a long random secret in production
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET
JWT_EXPIRE=7d

# Cloudinary (document / image uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Python prediction microservice (internal)
PYTHON_SERVICE_URL=http://127.0.0.1:5001
